{
  "api": {
    "port": 9099,
    "host": "0.0.0.0",
    "tls": {
      "enabled": false,
      "cert_file": "/opt/pve-hwmonitor/cert.pem",
      "key_file": "/opt/pve-hwmonitor/key.pem",
      "auto_generate": true
    },
    "security": {
      "token": null,
      "cors_origins": ["*"],
      "rate_limit": 10,
      "rate_window": 1.0,
      "audit_log": false,
      "audit_file": "/opt/pve-hwmonitor/audit.log"
    }
  },
  "sensor": {
    "has_ec": false,
    "ec_fan_regs": [],
    "has_boost": false,
    "has_ipmi": false,
    "ipmi_interface": "open",
    "ipmi_has_fans": false,
    "ipmi_has_temps": false,
    "ipmi_has_power": false,
    "ipmi_has_psu": false,
    "ipmi_has_voltage": false,
    "paths": {
      "ec_path": "/sys/kernel/debug/ec/ec0/io",
      "boost_path": null,
      "bat_path": null,
      "hw_coretemp": null,
      "hw_nvme": null,
      "hw_pch": null
    }
  },
  "alert": {
    "enabled": true,
    "thresholds": {
      "cpu_warn": 80.0,
      "cpu_crit": 90.0,
      "nvme_warn": 55.0,
      "nvme_crit": 70.0,
      "battery_warn": 20.0,
      "battery_crit": 10.0,
      "fan_min_rpm": 500
    }
  },
  "cluster": {
    "enabled": false,
    "poll_interval": 3.0,
    "nodes": []
  },
  "cache": {
    "ipmi_cache_ttl": 2.0,
    "ipmi_cache_file": "/opt/pve-hwmonitor/ipmi_cache.json"
  },
  "history": {
    "enabled": true,
    "max_points": 100,
    "retention_minutes": 60
  },
  "system_model": "",
  "bios_ver": "",
  "sdr_cache": "/opt/pve-hwmonitor/sdr.cache"
}
